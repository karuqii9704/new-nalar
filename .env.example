# Environment variables for the NALAR hackathon microsite.
# Copy this file to .env.local and fill in real values. Every var below is
# read via process.env.* somewhere in src/. The app degrades gracefully
# (falls back to seed data / deterministic templates) when a var is absent,
# except where marked "required".

# ---------------------------------------------------------------------------
# Supabase (NALAR live layer: POS sales + customer reviews written at runtime)
# Required for /kasir writes and live dashboard updates to persist across
# devices. Without it, the app still runs on the deterministic seed data.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase project URL. Required for the live layer.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase service-role key, server-only (never expose to the browser). Required for the live layer.

# ---------------------------------------------------------------------------
# Committee Postgres (NALAR Nasional: read-only /nasional data, ~1,026 rows)
# Required for the /nasional page. Without it, that page has no data source.
# ---------------------------------------------------------------------------
HACK_DB_HOST=localhost
# Committee Postgres host. Required for /nasional.
HACK_DB_PORT=5432
# Committee Postgres port. Optional, defaults to 5432.
HACK_DB_NAME=your_database_name
# Committee Postgres database name. Required for /nasional.
HACK_DB_USER=your_db_user
# Committee Postgres user. Required for /nasional.
HACK_DB_PASSWORD=your_db_password
# Committee Postgres password. Required for /nasional.
HACK_DB_SSL=1
# Set to "1" to require SSL (rejectUnauthorized: false); any other value disables SSL. Optional.

# ---------------------------------------------------------------------------
# AI (NALAR director chatbot narration)
# Optional: without it, /asisten falls back to a deterministic template.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
# Google Gemini API key for the /asisten chatbot. Optional (deterministic fallback if absent).

# ---------------------------------------------------------------------------
# Maps (NALAR Nasional store map)
# Optional: without it, /nasional falls back to an inline SVG scatter map.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MAPS_KEY=your-google-maps-key
# Google Maps API key (public, browser-exposed) for the /nasional map. Optional (SVG fallback if absent).
# Alias also supported by the app:
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
